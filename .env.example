# myHQ GTM Engine — Environment Variables
# Copy to .env and fill in your keys

# SerpAPI — Google Search, News, Trends, Twitter
SERP_API_KEY=your_serpapi_key_here

# ScraperAPI — LinkedIn, Naukri, website scraping
SCRAPER_API_KEY=your_scraperapi_key_here

# Apollo.io — Contact enrichment
APOLLO_API_KEY=your_apollo_key_here

# Anthropic — Outreach generation with Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# Supabase — Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_id_here

# Pipeline settings
DRY_RUN=true
LOG_LEVEL=INFO
