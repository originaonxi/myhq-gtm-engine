# ─────────────────────────────────────────
# myHQ GTM Engine v2 — API Keys
# ─────────────────────────────────────────

# ── TIER 1 — Signal Detection (India-primary) ──

# Tracxn — structured Indian funding data (PRIMARY signal source)
# Get from: tracxn.com/api
# Cost: ~$600/month (subscription, contact them)
TRACXN_API_KEY=

# Crunchbase — secondary funding, cross-reference
# Get from: data.crunchbase.com/docs
# Cost: $199/month Pro
CRUNCHBASE_API_KEY=

# NewsAPI — Indian startup news (entrackr, inc42, yourstory)
# Get from: newsapi.org
# Cost: $449/month Business tier
NEWS_API_KEY=

# Apify — Naukri scraping + property signals
# Get from: apify.com
# Cost: ~$100/month (usage-based)
APIFY_TOKEN=

# ── TIER 2 — Contact Enrichment (waterfall) ──

# Apollo.io — general enrichment (step 1 in waterfall)
# Get from: apollo.io/settings/integrations/api
# Cost: $99/month Growth
APOLLO_API_KEY=

# People Data Labs — tech roles, better email accuracy (step 2)
# Get from: peopledatalabs.com/api
# Cost: $0.01/enrichment
PDL_API_KEY=

# Netrows — 48+ LinkedIn endpoints, real-time (step 3)
# Replaces Proxycurl (shut down by LinkedIn lawsuit Jan 2025)
# Get from: netrows.com — docs at netrows.com/docs
# Cost: €0.005/request (~€49/mo starter, €299/mo growth)
NETROWS_API_KEY=

# Lusha — best WhatsApp/mobile numbers (step 4)
# Get from: lusha.com/developers
# Cost: $29/month Starter
LUSHA_API_KEY=

# Hunter.io — email-only fallback (step 5)
# Get from: hunter.io/api
# Cost: Free 25/mo, $49/mo Starter
HUNTER_API_KEY=

# ── TIER 3 — Verification (India-critical) ──

# Millionverifier — email verification
# Get from: millionverifier.com
# Cost: ~$20/month
MILLIONVERIFIER_KEY=

# MSG91 — WhatsApp verification (India-specific, TRAI-compliant)
# Get from: msg91.com
# Cost: ~$30/month
MSG91_API_KEY=

# TRAI DND — Indian regulatory DND check
# Get from: trai.gov.in or paid API providers
TRAI_DND_KEY=

# WhatsApp Business API
# Get from: msg91.com/whatsapp or business.whatsapp.com
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── TIER 4 — AI + Memory ──

# Anthropic — Claude Haiku for PKM + outreach generation
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=

# Airtable — single brain (shared with AROS + ARIA)
# Get from: airtable.com/create/tokens
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ── TIER 5 — Delivery ──

# Instantly — email campaigns
INSTANTLY_API_KEY=

# Gmail SMTP (fallback)
SMTP_USER=
SMTP_PASS=

# ── TIER 6 — WhatsApp Automation (Gupshup BSP) ──

# Gupshup — India-native BSP, Meta certified
# Why Gupshup: higher limits, TRAI native, Hindi support, since 2004
# Get from: gupshup.io/developer/whatsapp-business-api
# Cost: ~15,000-20,000 INR/month + per-message
# Setup: 48h to get verified number
GUPSHUP_APP_NAME=
GUPSHUP_API_KEY=
GUPSHUP_SOURCE_NUMBER=

# ── TIER 7 — Competitor Scraping ──

# SerpAPI — Google Reviews mining for competitor pain points
# Get from: serpapi.com
# Cost: $50/month for 5000 searches
SERPAPI_KEY=

# (Apify already set above — reused for competitor website crawling)

# ── TIER 8 — LLM Content Indexing ──

# Perplexity API — real-time content indexing (fastest path to LLM presence)
# Get from: perplexity.ai/api
# Cost: minimal per submission
PERPLEXITY_API_KEY=

# ── Alerts ──

# Email for HOT lead alerts (fires within 60s of HOT WA reply)
ALERT_EMAIL=

# ── Pipeline flags ──
DRY_RUN=true
LOG_LEVEL=INFO

# ─────────────────────────────────────────
# Monthly API cost estimate at production scale:
#   Tracxn API          ~$600/month
#   Crunchbase Pro      $199/month
#   NewsAPI Business    $449/month
#   Apify               ~$100/month
#   Apollo Growth       $99/month
#   People Data Labs    ~$50/month
#   Netrows             ~$55/month (€49 starter)
#   Lusha Starter       $29/month
#   Millionverifier     ~$20/month
#   MSG91               ~$30/month
#   Gupshup WA          ~$200/month (15-20K INR)
#   SerpAPI              $50/month
#   Perplexity           ~$20/month
#   TOTAL               ~$1,876/month
# ─────────────────────────────────────────
